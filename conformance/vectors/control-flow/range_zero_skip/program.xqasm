; range_zero_skip: RANGE with count=0 must skip the loop body.
;
; calldata[0] = 0 (count), sentinel r1 = 7.
; If the body runs, r1 gets overwritten to 99.
; Expected: output[0] = 7 (body was skipped).

PUSH 7
STOW r1        ; r1 = 7 (sentinel)

PUSH 0
PUSH 0
INPUT r0       ; r0 = calldata[0] = 0
LOAD r0
RANGE          ; loop [0, 0+0) -- empty, should skip
PUSH 99
STOW r1        ; would overwrite sentinel
NEXT

PUSH 0
OUTPUT r1
HALT
