; jumpi_taken: when calldata[0] != 0, write 1 to output[0]; otherwise 0.
;
; Exercises JUMPI + basic block targeting. Integer labels are the
; portable form shared by the Rust and Python assemblers.

PUSH 0
INPUT r0
LOAD r0
JUMPI .0        ; if non-zero, branch to label 0

; zero branch: output 0, then jump to end
PUSH 0
STOW r1
JUMP .1

TARGET .0        ; non-zero branch
PUSH 1
STOW r1

TARGET .1        ; end
PUSH 0
OUTPUT r1
HALT
